[MASTER]
ignore=.venv
; Skip Alembic migration scripts: they are autogenerated and use alembic.op's
; dynamically-attached members, which pylint flags as false-positive no-member.
ignore-paths=^\.venv/.*$|^alembic/.*$
init-hook='import sys; sys.path.append("/app")'

[MESSAGES CONTROL]
disable=too-few-public-methods,invalid-name,R0801
; Reason: too-few-public-methods is too restrictive for our use case, and R0801
; (Similar lines in 2 files) is being disabled to avoid spurious duplicate code warnings.
; invalid-name is disabled to allow for more flexibility in naming conventions.
